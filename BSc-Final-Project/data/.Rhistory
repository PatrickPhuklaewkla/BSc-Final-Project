setwd("~/GitHub/BSc-Final-Project/BSc-Final-Project/data")
library(tidyverse)
library(VennDiagram)
library(grid)
# Load data
ipa <- read_csv("biomart_cytokine_restricted_IPA_URA_TSTd2vsSaline_fdrsig_648size.csv",
show_col_types = FALSE)
string <- read_csv("cytokine_restricted_STRING_URA_TSTd2vsSaline_fdrsig_1309size.csv",
show_col_types = FALSE)
cytosig <- read_csv("TST CytoSig/cytokine_restricted_cytosig_formatted_significant_UR_output.csv",
show_col_types = FALSE)
# Unique regulator sets
ipa_regs <- unique(ipa$regulator)
string_regs <- unique(string$regulator)
cytosig_regs <- unique(cytosig$regulator)
# Counts
area1 <- length(ipa_regs)
area2 <- length(string_regs)
area3 <- length(cytosig_regs)
n12 <- length(intersect(ipa_regs, string_regs))
n13 <- length(intersect(ipa_regs, cytosig_regs))
n23 <- length(intersect(string_regs, cytosig_regs))
n123 <- length(Reduce(intersect, list(ipa_regs, string_regs, cytosig_regs)))
# Draw triple Venn
venn.plot <- draw.triple.venn(
area1 = area1,
area2 = area2,
area3 = area3,
n12 = n12,
n13 = n13,
n23 = n23,
n123 = n123,
category = c("IPA", "STRING", "CytoSig"),
fill = c("#E69F00", "#009E73", "#56B4E9"),  # orange, green, blue
alpha = 0.6,
cex = 1.5,
cat.cex = 1.4,
margin = 0.08
)
# Save as vector PDF
pdf("URA_IPA_STRING_CytoSig_Venn_Diagram.pdf", width = 7, height = 6)
grid.draw(venn.plot)
dev.off()
library(tidyverse)
library(VennDiagram)
library(grid)
# Load data
ipa <- read_csv("biomart_cytokine_restricted_IPA_URA_TSTd2vsSaline_fdrsig_648size.csv",
show_col_types = FALSE)
string <- read_csv("cytokine_restricted_STRING_URA_TSTd2vsSaline_fdrsig_1309size.csv",
show_col_types = FALSE)
cytosig <- read_csv("TST CytoSig/cytokine_restricted_cytosig_formatted_significant_UR_output.csv",
show_col_types = FALSE)
# Unique regulator sets
ipa_regs <- unique(ipa$regulator)
string_regs <- unique(string$regulator)
cytosig_regs <- unique(cytosig$regulator)
# Areas
area1 <- length(ipa_regs)
area2 <- length(string_regs)
area3 <- length(cytosig_regs)
# Overlaps
n12 <- length(intersect(ipa_regs, string_regs))
n13 <- length(intersect(ipa_regs, cytosig_regs))
n23 <- length(intersect(string_regs, cytosig_regs))
n123 <- length(Reduce(intersect, list(ipa_regs, string_regs, cytosig_regs)))
# Draw publication-style Venn
venn.plot <- draw.triple.venn(
area1 = area1,
area2 = area2,
area3 = area3,
n12 = n12,
n13 = n13,
n23 = n23,
n123 = n123,
category = c("IPA URA", "STRING URA", "CytoSig"),
fill = c("#D55E00", "#009E73", "#0072B2"),  # colour-blind safe palette
alpha = c(0.5, 0.5, 0.5),
lwd = 2,
col = "black",
cex = 1.6,
fontface = "bold",
cat.cex = 1.4,
cat.fontface = "bold",
cat.dist = c(0.08, 0.08, 0.08),
cat.pos = c(-20, 20, 180),
margin = 0.1
)
# Save high-quality vector figure
pdf("URA_IPA_STRING_CytoSig_Venn_publication.pdf", width = 8, height = 7)
grid.draw(venn.plot)
dev.off()
grid.draw(venn.plot)
# Draw publication-style Venn
venn.plot <- draw.triple.venn(
area1 = area1,
area2 = area2,
area3 = area3,
n12 = n12,
n13 = n13,
n23 = n23,
n123 = n123,
category = c("IPA", "STRING", "CytoSig"),
fill = c("#D55E00", "#009E73", "#0072B2"),
alpha = c(0.5, 0.5, 0.5),
lwd = 2,
col = "black",
cex = 1.6,
fontface = "bold",
cat.cex = 1.4,
cat.fontface = "bold",
cat.dist = c(0.08, 0.08, 0.06),
cat.pos = c(-20, 20, 170),
margin = 0.1
)
grid.draw(venn.plot)
# Save high-quality vector figure
pdf("URA_IPA_STRING_CytoSig_Venn_publication.pdf", width = 8, height = 7)
dev.off()
