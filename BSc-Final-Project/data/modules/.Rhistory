getwd()
library(tidyverse)
library(data.table)
library(biomaRt)
library(rstatix)
listEnsembl() # check current version
ensembl <- useEnsembl(biomart = "genes",
#version = 114, # only needed if using archived version
dataset = "hsapiens_gene_ensembl")
attributes <- listAttributes(ensembl)
biomart <- getBM(
attributes = c("ensembl_gene_id", "external_gene_name","gene_biotype"),
mart = ensembl
)
# reference = ~20k protein-coding genes
type <- unique(biomart$gene_biotype)
type_protein <- c("protein_coding",
"IG_V_gene","IG_C_gene","IG_J_gene","IG_D_gene",
"TR_V_gene","TR_C_gene","TR_J_gene","TR_D_gene")
biomart_protein <- biomart %>%
filter(gene_biotype %in% type_protein)
## Step 2: Load interaction database and subset to reference genes ####
# SIGNOR: downloaded from https://signor.uniroma2.it/downloads.php
signor_db <- read.table("../interaction_db_files/all_data_28_11_25.tsv",
header = TRUE,
sep = "\t",
fill = TRUE,
quote = "")
signor_filt <- signor_db %>%
filter(!TYPEA %in% c("chemical","stimulus","phenotype","smallmolecule") &
!TYPEB %in% c("chemical","stimulus","phenotype","smallmolecule") &
ENTITYA %in% biomart_protein$external_gene_name & # this line not strictly necessary, depends on whether we want to restrict reported UR to known gene/protein names or not
ENTITYB %in% biomart_protein$external_gene_name)
## Step 3: Load gene list of interest (genes up-regulated in D2 TST) and subset to reference genes ####
dat <- read.table("../data/IPA_input_D2-TSTvsSaline.txt",
header = TRUE)
dat_annot <- dat %>%
dplyr::rename(ensembl_gene_id = "Id") %>%
left_join(biomart_protein) %>%
select(external_gene_name,log2FoldChange) %>%
group_by(external_gene_name) %>%
filter(log2FoldChange == max(log2FoldChange) &
!is.na(external_gene_name) &
!external_gene_name == "") %>%
unique() %>%
ungroup()
deg_up <- dat_annot %>% filter(log2FoldChange>0)
deg_down <- dat_annot %>% filter(log2FoldChange<0)
## Step 4: Choose example upstream regulator ####
# SIGNOR
unique(signor_filt$EFFECT)
ur_network_signor <- signor_filt %>%
filter(ENTITYA == "IFNG") %>%
select(ENTITYA,ENTITYB,SCORE,EFFECT) %>%
unique() %>%
mutate(edge = ifelse(str_detect(EFFECT,"up-regulates"),
SCORE,
ifelse(str_detect(EFFECT,"down-regulates"),
SCORE*(-1),
NA))) %>%
na.omit() %>% # remove interactions without listed directionality
select(ENTITYA,ENTITYB,SCORE,edge) %>%
unique() # keep only unique interactions irrespective of the exact wording of the effect
## Step 5: calculate Z-score ####
n <- nrow(ur_network_signor)
n_concord <- ur_network_signor %>%
filter((ENTITYB %in% deg_up$external_gene_name & edge > 0)
| (ENTITYB %in% deg_down$external_gene_name & edge < 0)) %>%
pull(SCORE) %>%
sum()
n_discord <- ur_network_signor %>%
filter((ENTITYB %in% deg_up$external_gene_name & edge < 0)
| (ENTITYB %in% deg_down$external_gene_name & edge > 0)) %>%
pull(SCORE) %>%
sum()
z <- (n_concord-n_discord)/sqrt(n)
View(ur_network_signor)
library(tidyverse)
library(data.table)
library(biomaRt)
library(rstatix)
## Step 1: Load reference genes ####
# https://bioconductor.org/packages/release/bioc/vignettes/biomaRt/inst/doc/accessing_ensembl.html
listEnsembl() # check current version
#listEnsemblArchives() # check archived versions
ensembl <- useEnsembl(biomart = "genes",
#version = 114, # only needed if using archived version
dataset = "hsapiens_gene_ensembl")
attributes <- listAttributes(ensembl)
biomart <- getBM(
attributes = c("ensembl_gene_id", "external_gene_name","gene_biotype"),
mart = ensembl
)
# reference = ~20k protein-coding genes
type <- unique(biomart$gene_biotype)
type_protein <- c("protein_coding",
"IG_V_gene","IG_C_gene","IG_J_gene","IG_D_gene",
"TR_V_gene","TR_C_gene","TR_J_gene","TR_D_gene")
biomart_protein <- biomart %>%
filter(gene_biotype %in% type_protein)
## Step 2: Load interaction database and subset to reference genes ####
# STRING: downloaded from https://string-db.org/cgi/download?sessionId=bgFsQUBM6MYS&species_text=Homo+sapiens
string_db <- fread("interaction_db_files/9606.protein.links.full.v12.0.txt.gz")
## Step 2: Load interaction database and subset to reference genes ####
# STRING: downloaded from https://string-db.org/cgi/download?sessionId=bgFsQUBM6MYS&species_text=Homo+sapiens
string_db <- fread("interaction_db_files/9606.protein.links.full.v12.0.txt.gz")
